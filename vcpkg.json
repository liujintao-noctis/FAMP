{
  "name": "famp",
  "version-string": "0.1.0",
  "description": "Field Archaeology Mapping Program",
  "builtin-baseline": "a0b1c8d3a477c1cb4813d8e127a56961707ca42b",
  "dependencies": [
    {
      "name": "qtbase",
      "default-features": false,
      "features": [
        "gui",
        "widgets",
        "opengl",
        "png",
        "jpeg",
        "thread"
      ]
    },
    {
      "name": "qtbase",
      "default-features": false,
      "features": [
        "fontconfig",
        "xcb",
        "xcb-sm",
        "xcb-xlib",
        "xrender"
      ],
      "platform": "linux"
    },
    {
      "name": "vtk",
      "default-features": false,
      "features": [
        "opengl",
        "qt"
      ]
    },
    {
      "name": "pcl",
      "default-features": false,
      "features": [
        "visualization"
      ]
    }
  ]
}
